# ============================================================
#  Garuda Express v5 — Environment Configuration
#  Copy this file to .env and fill in your values
# ============================================================

PORT=3000
NODE_ENV=production
LOG_LEVEL=info
ALLOWED_ORIGIN=*

# ── Admin & Portal credentials ────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=garuda2024

# Portal has its own separate login
PORTAL_USER=portal
PORTAL_PASS=garuda2024

# ── DHL Official API ──────────────────────────────────────
# Register free at: https://developer.dhl.com
# Used ONLY for DHL shipments — falls back to 17track if not set
DHL_API_KEY=your_dhl_api_key_here

# ── FedEx OAuth2 API ──────────────────────────────────────
# Register free at: https://developer.fedex.com
# Used ONLY for FedEx shipments — falls back to 17track if not set
FEDEX_API_KEY=your_fedex_api_key_here
FEDEX_API_SECRET=your_fedex_api_secret_here

# ── UPS OAuth2 API ────────────────────────────────────────
# Register free at: https://developer.ups.com
# Used ONLY for UPS shipments — falls back to 17track if not set
UPS_CLIENT_ID=your_ups_client_id_here
UPS_CLIENT_SECRET=your_ups_client_secret_here

# ── 17track Universal Fallback ────────────────────────────
# Works WITHOUT a key (free public endpoint, limited rate)
# Register free at: https://www.17track.net/en/api
# Free tier: 100 registrations/day — upgrade for production use
TRACK17_API_KEY= 0E319E804F5FD15912D13A829B6EC143
