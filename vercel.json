{
  "version": 2,
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "trailingSlash": false,
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/Admin/?",  "dest": "/Admin/index.html" },
    { "src": "/portal/?", "dest": "/portal/index.html" },
    { "src": "/dashboard/?", "dest": "/dashboard/index.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
